{
    "workbench.iconTheme": "vscode-icons",
    "workbench.editor.labelFormat": "short",
    "workbench.startupEditor": "newUntitledFile",
    "workbench.sideBar.location": "left",
    "workbench.colorTheme": "One Dark Pro",
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "tsimporter.emitSemicolon": false,
    "tsimporter.preferRelative": true,
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "window.zoomLevel": 0,
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    // From web-repo
    "files.exclude": {
        "**/.next": true,
        "**/generated_assets": true,
        "**/out": true
    },
    "files.watcherExclude": {
        "**/.next": true,
        "**/generated_assets": true
    },
    "search.exclude": {
        "**/dist": true
    },
    "eslint.enable": true,
    "eslint.workingDirectories": [
        {
            "directory": "./frontend",
            "changeProcessCWD": true
        },
        {
            "directory": "./design",
            "changeProcessCWD": true
        },
        {
            "directory": "./web-app",
            "changeProcessCWD": true
        },
        {
            "directory": "./static-sites",
            "changeProcessCWD": true
        },
        {
            "directory": "./shared-modules",
            "changeProcessCWD": true
        },
    ],
    "eslint.runtime": "/usr/local/bin/node",
    "eslint.validate": [
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact"
    ],
    "editor.codeActionsOnSave": {
        // Use eslint-vscode for auto-fixing files. This includes prettier.
        "source.fixAll.eslint": true
    },
    // Enable formatOnSave by default
    "editor.formatOnSave": true,
    // Disable the formatOnSave for languages that should instead use the "eslint --fix" equivalent via codeActionsOnSave
    "[javascript]": {
        "editor.formatOnSave": false
    },
    "[javascriptreact]": {
        "editor.formatOnSave": false
    },
    "[typescript]": {
        "editor.formatOnSave": false
    },
    "[typescriptreact]": {
        "editor.formatOnSave": false
    },
    // Set Yarn as the package manager
    "eslint.packageManager": "yarn",
    "npm.packageManager": "yarn",
    "todo-tree.tree.showScanModeButton": false
}
